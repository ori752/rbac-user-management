{
  "name": "rbac-user-management",
  "version": "1.2.0",
  "description": "Enterprise-grade RBAC API + Guesty property pipeline automation",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "typecheck:scripts": "tsc --noEmit --project tsconfig.scripts.json",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "crawl": "ts-node --project tsconfig.scripts.json scripts/crawl-to-guesty.ts",
    "leads": "ts-node --project tsconfig.scripts.json scripts/prospecting/run.ts"
  },
  "keywords": [
    "rbac",
    "auth",
    "typescript",
    "express"
  ],
  "author": "Ori",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.107.0",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^9.0.1",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^8.0.1",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^11.0.0",
    "jest": "^29.7.0",
    "playwright": "^1.61.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
