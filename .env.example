# ─────────────────────────────────────────────────────────────────────────────
# Guesty Sandbox API Credentials
# Obtain from: https://app.guesty.com → Integrations → API → Create Application
# ─────────────────────────────────────────────────────────────────────────────
GUESTY_CLIENT_ID=
GUESTY_CLIENT_SECRET=

# Override only if you target a non-standard Guesty environment (default shown)
# GUESTY_API_BASE=https://open-api.guesty.com

# ─────────────────────────────────────────────────────────────────────────────
# Manager Notification — Email (SMTP)
# All four vars must be set for email notifications to fire.
# Gmail example: SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USER=you@gmail.com
# Use an App Password (not your account password) when 2FA is enabled.
# ─────────────────────────────────────────────────────────────────────────────
NOTIFY_EMAIL_TO=manager@example.com
NOTIFY_EMAIL_FROM=automation@yourcompany.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─────────────────────────────────────────────────────────────────────────────
# Manager Notification — Slack Incoming Webhook
# Create at: https://api.slack.com/apps → Incoming Webhooks
# If unset, Slack notification is silently skipped.
# ─────────────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Existing RBAC server variables (unchanged)
# ─────────────────────────────────────────────────────────────────────────────
PORT=3000
JWT_SECRET=dev-secret-change-in-prod
NODE_ENV=development
ALLOWED_ORIGINS=
