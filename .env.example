# ─────────────────────────────────────────────────────────────────────────────
# Guesty Sandbox API Credentials
# Obtain from: https://app.guesty.com → Integrations → API → Create Application
# ─────────────────────────────────────────────────────────────────────────────
GUESTY_CLIENT_ID=
GUESTY_CLIENT_SECRET=

# Override only if you target a non-standard Guesty environment (default shown)
# GUESTY_API_BASE=https://open-api.guesty.com

# ─────────────────────────────────────────────────────────────────────────────
# Manager Notification — Email (SMTP)
# All four vars must be set for email notifications to fire.
# Gmail example: SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USER=you@gmail.com
# Use an App Password (not your account password) when 2FA is enabled.
# ─────────────────────────────────────────────────────────────────────────────
NOTIFY_EMAIL_TO=manager@example.com
NOTIFY_EMAIL_FROM=automation@yourcompany.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─────────────────────────────────────────────────────────────────────────────
# Manager Notification — Slack Incoming Webhook
# Create at: https://api.slack.com/apps → Incoming Webhooks
# If unset, Slack notification is silently skipped.
# ─────────────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Host Lead Intelligence (prospecting module)
# ─────────────────────────────────────────────────────────────────────────────
# Anthropic API key for LLM review analysis. If UNSET, the pipeline falls back to
# a deterministic offline analyzer, so the feature runs end-to-end at zero cost.
ANTHROPIC_API_KEY=
# Model for the per-review classification loop (default: claude-sonnet-4-6).
LEADS_MODEL=claude-sonnet-4-6
# Qualified-lead distress floor (0–100, default 40). Hosts scoring below this are
# excluded from the report — it is never padded with healthy/low-distress hosts.
LEADS_MIN_DISTRESS=40
# Default listing source for `npm run leads` and the web "Run pipeline" button:
#   fixture (default) — committed sample data, zero network
#   guesty            — YOUR OWN listings via the official Guesty API (reuses the
#                       GUESTY_CLIENT_ID / GUESTY_CLIENT_SECRET below); powers the
#                       portfolio-health view (which managed listings need attention)
#   partner           — documented stub for a licensed/partner feed
LEADS_SOURCE=fixture
# Optional credentials for a COMPLIANT partner/licensed data source (the
# `partner` adapter). Left blank, that adapter is a documented stub; the default
# `fixture` source needs nothing and performs no scraping.
# LEADS_PARTNER_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Existing RBAC server variables (unchanged)
# ─────────────────────────────────────────────────────────────────────────────
PORT=3000
JWT_SECRET=dev-secret-change-in-prod
NODE_ENV=development
ALLOWED_ORIGINS=
